generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id                   String                @id @default(cuid())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  name                 String
  code                 String                @unique
  academicSessions     AcademicSession[]
  auditLogs            AuditLog[]
  classes              Class[]
  documents            Document[]
  families             Family[]
  feeHeads             FeeHead[]
  gradeScales          GradeScale[]
  holidays             Holiday[]
  importJobs           ImportJob[]
  notices              Notice[]
  notificationChannels NotificationChannel[]
  branding             SchoolBranding?
  staffProfiles        StaffProfile[]
  students             Student[]
  subjects             Subject[]
  users                User[]
}

model SchoolBranding {
  id                           String   @id @default(cuid())
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  schoolId                     String   @unique
  schoolName                   String
  address                      String?
  phone                        String?
  email                        String?
  website                      String?
  principalName                String?
  logoDocumentId               String?
  principalSignatureDocumentId String?
  schoolStampDocumentId        String?
  qrCodeDocumentId             String?
  receiptFooter                String?
  reportCardFooter             String?
  school                       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model User {
  id                 String                 @id @default(cuid())
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  name               String
  email              String                 @unique
  emailVerified      Boolean                @default(false)
  image              String?
  role               Role                   @default(STUDENT)
  isActive           Boolean                @default(true)
  mustChangePassword Boolean                @default(false)
  loginIdentifier    String?
  schoolId           String?
  staffProfileId     String?                @unique
  studentId          String?                @unique
  accounts           Account[]
  admissionsReviewed AdmissionApplication[] @relation("AdmissionReviewer")
  attendanceMarked   AttendanceRecord[]     @relation("AttendanceMarker")
  auditLogs          AuditLog[]
  paymentsRecorded   FamilyPayment[]        @relation("PaymentRecorder")
  importJobs         ImportJob[]
  leavesApproved     LeaveRequest[]         @relation("LeaveApprover")
  marksEntered       MarkEntry[]            @relation("MarksEnterer")
  noticesCreated     Notice[]               @relation("NoticeCreator")
  promotions         PromotionHistory[]     @relation("PromotionActor")
  sessions           Session[]
  school             School?                @relation(fields: [schoolId], references: [id])
  staffProfile       StaffProfile?          @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  student            Student?               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  userPermissions    UserPermission[]

  @@unique([schoolId, loginIdentifier])
  @@index([schoolId, role])
  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  identifier String
  value      String
  expiresAt  DateTime

  @@index([identifier])
}

model Permission {
  id              String           @id @default(cuid())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  resource        String
  action          String
  key             String           @unique
  description     String?
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@index([resource])
}

model RolePermission {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  role         Role
  permissionId String
  allowed      Boolean    @default(true)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
}

model UserPermission {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  userId       String
  permissionId String
  allowed      Boolean
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}

model StaffProfile {
  id                      String                   @id @default(cuid())
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  schoolId                String
  employeeCode            String
  fullName                String
  phone                   String?
  designation             String?
  role                    Role
  isActive                Boolean                  @default(true)
  classTeacherAssignments ClassTeacherAssignment[]
  homework                Homework[]
  leaveRequests           LeaveRequest[]
  school                  School                   @relation(fields: [schoolId], references: [id])
  timetableSlots          TimetableSlot[]
  user                    User?

  @@unique([schoolId, employeeCode])
  @@index([schoolId, fullName])
}

model AcademicSession {
  id                      String                   @id @default(cuid())
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  schoolId                String
  name                    String
  startDate               DateTime
  endDate                 DateTime
  status                  SessionStatus            @default(DRAFT)
  isCurrent               Boolean                  @default(false)
  school                  School                   @relation(fields: [schoolId], references: [id])
  admissions              AdmissionApplication[]
  attendanceRecords       AttendanceRecord[]
  classSubjects           ClassSubject[]
  classTeacherAssignments ClassTeacherAssignment[]
  exams                   Exam[]
  examTypes               ExamType[]
  feeStructures           FeeStructure[]
  homework                Homework[]
  promotionsFrom          PromotionHistory[]       @relation("FromSession")
  promotionsTo            PromotionHistory[]       @relation("ToSession")
  reportCards             ReportCard[]
  enrollments             StudentEnrollment[]
  studentFees             StudentFee[]
  timetableSlots          TimetableSlot[]

  @@unique([schoolId, name])
  @@index([schoolId, isCurrent])
}

model Class {
  id             String                 @id @default(cuid())
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  schoolId       String
  name           String
  sortOrder      Int                    @default(0)
  admissions     AdmissionApplication[]
  school         School                 @relation(fields: [schoolId], references: [id])
  classSubjects  ClassSubject[]
  exams          Exam[]
  feeStructures  FeeStructure[]
  promotionsFrom PromotionHistory[]     @relation("FromClass")
  promotionsTo   PromotionHistory[]     @relation("ToClass")
  sections       Section[]
  enrollments    StudentEnrollment[]

  @@unique([schoolId, name])
  @@index([schoolId, sortOrder])
}

model Section {
  id                      String                   @id @default(cuid())
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  classId                 String
  name                    String
  classTeacherAssignments ClassTeacherAssignment[]
  homework                Homework[]
  promotionsFrom          PromotionHistory[]       @relation("FromSection")
  promotionsTo            PromotionHistory[]       @relation("ToSection")
  class                   Class                    @relation(fields: [classId], references: [id], onDelete: Cascade)
  enrollments             StudentEnrollment[]
  timetableSlots          TimetableSlot[]

  @@unique([classId, name])
}

model Subject {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  schoolId       String
  name           String
  code           String
  classSubjects  ClassSubject[]
  examSubjects   ExamSubject[]
  homework       Homework[]
  school         School          @relation(fields: [schoolId], references: [id])
  timetableSlots TimetableSlot[]

  @@unique([schoolId, code])
  @@unique([schoolId, name])
}

model ClassSubject {
  id        String          @id @default(cuid())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  sessionId String
  classId   String
  subjectId String
  class     Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  session   AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  subject   Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([sessionId, classId, subjectId])
}

model ClassTeacherAssignment {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  sessionId      String
  sectionId      String
  staffProfileId String
  section        Section         @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  session        AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  staffProfile   StaffProfile    @relation(fields: [staffProfileId], references: [id])

  @@unique([sessionId, sectionId])
  @@index([staffProfileId, sessionId])
}

model Family {
  id             String                 @id @default(cuid())
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  schoolId       String
  familyCode     String?
  fatherName     String?
  motherName     String?
  guardianName   String?
  primaryPhone   String?
  secondaryPhone String?
  email          String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  pincode        String?
  admissions     AdmissionApplication[]
  school         School                 @relation(fields: [schoolId], references: [id])
  payments       FamilyPayment[]
  students       Student[]

  @@unique([schoolId, familyCode])
  @@index([schoolId, fatherName])
  @@index([schoolId, motherName])
  @@index([schoolId, primaryPhone])
}

model Student {
  id             String                 @id @default(cuid())
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  schoolId       String
  familyId       String
  admissionNo    String
  firstName      String
  middleName     String?
  lastName       String?
  fullName       String
  dateOfBirth    DateTime
  gender         Gender?
  bloodGroup     String?
  aadhaar        String?
  status         StudentStatus          @default(ACTIVE)
  admissions     AdmissionApplication[]
  attendance     AttendanceRecord[]
  feeAllocations FeePaymentAllocation[]
  leaveRequests  LeaveRequest[]
  markEntries    MarkEntry[]
  promotions     PromotionHistory[]
  reportCards    ReportCard[]
  family         Family                 @relation(fields: [familyId], references: [id])
  school         School                 @relation(fields: [schoolId], references: [id])
  enrollments    StudentEnrollment[]
  studentFees    StudentFee[]
  medical        StudentMedical?
  user           User?

  @@unique([schoolId, admissionNo])
  @@index([schoolId, fullName])
  @@index([familyId])
  @@index([schoolId, status])
}

model StudentMedical {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  studentId  String   @unique
  allergies  String?
  conditions String?
  notes      String?
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model StudentEnrollment {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  studentId String
  sessionId String
  classId   String
  sectionId String
  rollNo    String?
  status    EnrollmentStatus @default(ACTIVE)
  class     Class            @relation(fields: [classId], references: [id])
  section   Section          @relation(fields: [sectionId], references: [id])
  session   AcademicSession  @relation(fields: [sessionId], references: [id])
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, sessionId])
  @@index([sessionId, sectionId])
  @@index([sessionId, classId])
}

model PromotionHistory {
  id            String          @id @default(cuid())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  studentId     String
  fromSessionId String
  toSessionId   String
  fromClassId   String
  toClassId     String
  fromSectionId String?
  toSectionId   String?
  promotedAt    DateTime        @default(now())
  byUserId      String?
  notes         String?
  byUser        User?           @relation("PromotionActor", fields: [byUserId], references: [id])
  fromClass     Class           @relation("FromClass", fields: [fromClassId], references: [id])
  fromSection   Section?        @relation("FromSection", fields: [fromSectionId], references: [id])
  fromSession   AcademicSession @relation("FromSession", fields: [fromSessionId], references: [id])
  student       Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  toClass       Class           @relation("ToClass", fields: [toClassId], references: [id])
  toSection     Section?        @relation("ToSection", fields: [toSectionId], references: [id])
  toSession     AcademicSession @relation("ToSession", fields: [toSessionId], references: [id])

  @@index([studentId])
}

model AdmissionApplication {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  sessionId      String
  familyId       String?
  studentId      String?
  applicantName  String
  dateOfBirth    DateTime
  gender         Gender?
  appliedClassId String
  fatherName     String?
  motherName     String?
  guardianName   String?
  phone          String?
  address        String?
  status         AdmissionStatus @default(PENDING)
  admissionNo    String?
  remarks        String?
  reviewedById   String?
  reviewedAt     DateTime?
  appliedClass   Class           @relation(fields: [appliedClassId], references: [id])
  family         Family?         @relation(fields: [familyId], references: [id])
  reviewedBy     User?           @relation("AdmissionReviewer", fields: [reviewedById], references: [id])
  session        AcademicSession @relation(fields: [sessionId], references: [id])
  student        Student?        @relation(fields: [studentId], references: [id])

  @@index([sessionId, status])
  @@index([admissionNo])
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  sessionId  String
  studentId  String
  date       DateTime         @db.Date
  status     AttendanceStatus
  remarks    String?
  markedById String?
  markedBy   User?            @relation("AttendanceMarker", fields: [markedById], references: [id])
  session    AcademicSession  @relation(fields: [sessionId], references: [id])
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([sessionId, date])
}

model LeaveRequest {
  id             String             @id @default(cuid())
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  requesterType  LeaveRequesterType
  studentId      String?
  staffProfileId String?
  fromDate       DateTime           @db.Date
  toDate         DateTime           @db.Date
  reason         String
  status         LeaveStatus        @default(PENDING)
  approvedById   String?
  reviewedAt     DateTime?
  remarks        String?
  approvedBy     User?              @relation("LeaveApprover", fields: [approvedById], references: [id])
  staffProfile   StaffProfile?      @relation(fields: [staffProfileId], references: [id])
  student        Student?           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([status, fromDate])
  @@index([studentId])
  @@index([staffProfileId])
}

model Holiday {
  id          String      @id @default(cuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  schoolId    String
  date        DateTime    @db.Date
  name        String
  description String?
  type        HolidayType @default(SCHOOL)
  school      School      @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, date])
  @@index([schoolId, date])
}

model TimetableSlot {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  sessionId      String
  sectionId      String
  dayOfWeek      DayOfWeek
  periodNumber   Int
  startTime      String
  endTime        String
  subjectId      String
  staffProfileId String
  section        Section         @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  session        AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  staffProfile   StaffProfile    @relation(fields: [staffProfileId], references: [id])
  subject        Subject         @relation(fields: [subjectId], references: [id])

  @@unique([sessionId, sectionId, dayOfWeek, periodNumber])
  @@index([staffProfileId, sessionId, dayOfWeek])
}

model Homework {
  id               String               @id @default(cuid())
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  sessionId        String
  sectionId        String
  subjectId        String
  title            String
  description      String?
  dueDate          DateTime
  createdByStaffId String
  createdByStaff   StaffProfile         @relation(fields: [createdByStaffId], references: [id])
  section          Section              @relation(fields: [sectionId], references: [id])
  session          AcademicSession      @relation(fields: [sessionId], references: [id])
  subject          Subject              @relation(fields: [subjectId], references: [id])
  attachments      HomeworkAttachment[]

  @@index([sectionId, dueDate])
  @@index([createdByStaffId])
}

model HomeworkAttachment {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  homeworkId String
  documentId String   @unique
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  homework   Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
}

model ExamType {
  id        String          @id @default(cuid())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  sessionId String
  name      String
  exams     Exam[]
  session   AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, name])
}

model Exam {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  sessionId   String
  examTypeId  String
  classId     String
  name        String
  startDate   DateTime?
  endDate     DateTime?
  class       Class           @relation(fields: [classId], references: [id])
  examType    ExamType        @relation(fields: [examTypeId], references: [id])
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  subjects    ExamSubject[]
  reportCards ReportCard[]

  @@index([sessionId, classId])
}

model ExamSubject {
  id          String      @id @default(cuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  examId      String
  subjectId   String
  maxMarks    Decimal     @db.Decimal(8, 2)
  passMarks   Decimal     @db.Decimal(8, 2)
  exam        Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject     Subject     @relation(fields: [subjectId], references: [id])
  markEntries MarkEntry[]

  @@unique([examId, subjectId])
}

model MarkEntry {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  examSubjectId String
  studentId     String
  marksObtained Decimal     @db.Decimal(8, 2)
  grade         String?
  remarks       String?
  enteredById   String?
  enteredBy     User?       @relation("MarksEnterer", fields: [enteredById], references: [id])
  examSubject   ExamSubject @relation(fields: [examSubjectId], references: [id], onDelete: Cascade)
  student       Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examSubjectId, studentId])
  @@index([studentId])
}

model GradeScale {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  schoolId   String
  minPercent Decimal  @db.Decimal(5, 2)
  maxPercent Decimal  @db.Decimal(5, 2)
  grade      String
  remarks    String?
  school     School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model ReportCard {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  studentId   String
  sessionId   String
  examId      String?
  snapshot    Json
  publishedAt DateTime?
  exam        Exam?           @relation(fields: [examId], references: [id])
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  student     Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, sessionId])
}

model FeeHead {
  id             String             @id @default(cuid())
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  schoolId       String
  name           String
  frequency      FeeFrequency       @default(MONTHLY)
  description    String?
  isActive       Boolean            @default(true)
  school         School             @relation(fields: [schoolId], references: [id])
  structureItems FeeStructureItem[]
  studentFees    StudentFee[]

  @@unique([schoolId, name])
}

model FeeStructure {
  id        String             @id @default(cuid())
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  sessionId String
  classId   String
  name      String
  class     Class              @relation(fields: [classId], references: [id])
  session   AcademicSession    @relation(fields: [sessionId], references: [id])
  items     FeeStructureItem[]

  @@unique([sessionId, classId, name])
}

model FeeStructureItem {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  feeStructureId String
  feeHeadId      String
  amount         Decimal      @db.Decimal(12, 2)
  feeHead        FeeHead      @relation(fields: [feeHeadId], references: [id])
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)

  @@unique([feeStructureId, feeHeadId])
}

model StudentFee {
  id          String                 @id @default(cuid())
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  studentId   String
  feeHeadId   String
  sessionId   String
  amount      Decimal                @db.Decimal(12, 2)
  dueDate     DateTime?
  status      StudentFeeStatus       @default(PENDING)
  remarks     String?
  allocations FeePaymentAllocation[]
  feeHead     FeeHead                @relation(fields: [feeHeadId], references: [id])
  session     AcademicSession        @relation(fields: [sessionId], references: [id])
  student     Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, sessionId, status])
  @@index([sessionId, status])
}

model FamilyPayment {
  id           String                 @id @default(cuid())
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  familyId     String
  amount       Decimal                @db.Decimal(12, 2)
  method       PaymentMethod
  referenceNo  String?
  paidAt       DateTime               @default(now())
  receiptNo    String                 @unique
  notes        String?
  recordedById String?
  family       Family                 @relation(fields: [familyId], references: [id])
  recordedBy   User?                  @relation("PaymentRecorder", fields: [recordedById], references: [id])
  allocations  FeePaymentAllocation[]
  receipt      FeeReceipt?

  @@index([familyId, paidAt])
}

model FeePaymentAllocation {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  paymentId    String
  studentId    String
  studentFeeId String?
  amount       Decimal       @db.Decimal(12, 2)
  payment      FamilyPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  studentFee   StudentFee?   @relation(fields: [studentFeeId], references: [id], onDelete: Cascade)
  student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([paymentId])
}

model FeeReceipt {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  paymentId String        @unique
  snapshot  Json
  payment   FamilyPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model Document {
  id                 String              @id @default(cuid())
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  schoolId           String
  ownerType          DocumentOwnerType
  ownerId            String
  type               DocumentType        @default(OTHER)
  fileName           String
  mimeType           String
  sizeBytes          Int
  checksum           String
  school             School              @relation(fields: [schoolId], references: [id])
  blob               DocumentBlob?
  homeworkAttachment HomeworkAttachment?

  @@index([schoolId, ownerType, ownerId])
  @@index([type])
}

model DocumentBlob {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  documentId String   @unique
  data       Bytes
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model Notice {
  id          String         @id @default(cuid())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  schoolId    String
  title       String
  body        String
  audience    NoticeAudience @default(ALL)
  publishedAt DateTime?
  createdById String?
  isActive    Boolean        @default(true)
  createdBy   User?          @relation("NoticeCreator", fields: [createdById], references: [id])
  school      School         @relation(fields: [schoolId], references: [id])

  @@index([schoolId, publishedAt])
}

model NotificationChannel {
  id        String                  @id @default(cuid())
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  schoolId  String
  type      NotificationChannelType
  enabled   Boolean                 @default(false)
  config    Json?
  school    School                  @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, type])
}

model AuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  schoolId   String?
  userId     String?
  action     String
  module     String
  entityType String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  school     School?  @relation(fields: [schoolId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([schoolId, createdAt])
  @@index([module, createdAt])
  @@index([entityType, entityId])
  @@index([userId, createdAt])
}

model ImportJob {
  id           String          @id @default(cuid())
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  schoolId     String
  type         ImportType
  status       ImportJobStatus @default(PENDING)
  successCount Int             @default(0)
  failCount    Int             @default(0)
  errorReport  Json?
  preview      Json?
  uploadedById String?
  school       School          @relation(fields: [schoolId], references: [id])
  uploadedBy   User?           @relation(fields: [uploadedById], references: [id])

  @@index([schoolId, createdAt])
}

